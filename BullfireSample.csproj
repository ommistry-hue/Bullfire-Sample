<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>BullfireSample</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Installed from NuGet. No project references into the Bullfire source tree — this sample
      proves the published NuGet packages work end-to-end exactly the way a real user consumes them.
    -->
    <PackageReference Include="Bullfire" Version="1.1.2" />
    <PackageReference Include="Bullfire.Dashboard" Version="1.1.2" />
  </ItemGroup>

</Project>
